<?xml version="1.0"?>
<MenuItems>
	<MenuItem id="captureDevice">
		<Name>Capture Device</Name>
		<CallbackMethod>captureDevice</CallbackMethod>
	</MenuItem>
	<MenuItem id="reviewCapture">
		<Name>Review Captured Data</Name>
		<CallbackMethod>reviewCapture</CallbackMethod>
	</MenuItem>
	<MenuItem id="submitCapture">
		<Name>Submit for Plugin Generation</Name>
		<CallbackMethod>submitCapture</CallbackMethod>
	</MenuItem>
	<MenuItem id="separator1" type="separator"/>
	<MenuItem id="reportIssue">
		<Name>Report Plugin Issue...</Name>
		<ButtonTitle>Submit Report</ButtonTitle>
		<CallbackMethod>reportIssue</CallbackMethod>
		<ConfigUI>
			<Field id="intro" type="label">
				<Label>Report an issue with a plugin generated by the factory. This creates a GitHub issue on that plugin's repo.</Label>
			</Field>
			<Field id="pluginRepo" type="textfield">
				<Label>Plugin repo (owner/name):</Label>
				<Description>e.g. simons-plugins/indigo-shelly-plus2pm</Description>
			</Field>
			<Field id="pluginVersion" type="textfield">
				<Label>Plugin version:</Label>
				<Description>Version of the plugin you're reporting on (from its Info.plist)</Description>
			</Field>
			<Field id="description" type="textfield">
				<Label>Short description:</Label>
				<Description>One-line summary of the problem</Description>
			</Field>
			<Field id="errorLog" type="textfield">
				<Label>Error log / traceback:</Label>
				<Description>Paste the relevant lines from the Indigo event log</Description>
			</Field>
		</ConfigUI>
	</MenuItem>
</MenuItems>
